{
  "compilerOptions": {
    /* Runtime alinhado com Bun — sem DOM */
    "target": "ES2022",
    "lib": ["ES2022"],

    /* ESM + resolução de módulos estilo bundler/tools */
    "module": "ES2022",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["bun-types"],

    /* Projeto compilado pelo Bun — tsc/tsgo só validam tipos */
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo.json",

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    /* Mais segurança sem chegar ao exactOptionalPropertyTypes */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "tests/**/*.ts", "drizzle.config.ts"],
  "exclude": ["node_modules"]
}

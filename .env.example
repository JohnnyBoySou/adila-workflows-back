NODE_ENV=development
PORT=3000
# trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/workflows

# Redis (BullMQ)
REDIS_URL=redis://127.0.0.1:6379

# ── Identity (adila.co) — provedor de identidade federado ──
# A auth vive no serviço Identity. O front minta um JWT curto lá e manda como
# `Authorization: Bearer`; este back valida stateless via JWKS. Ver lib/identity-auth.ts.
IDENTITY_URL=https://identity.adila.co
# Opcional — `iss` esperado no token; default = IDENTITY_URL.
IDENTITY_ISSUER=
# `aud` esperado (literal fixo no Identity).
IDENTITY_JWT_AUDIENCE=adila

# Criptografia de secrets em repouso — 32 bytes base64. Gere: openssl rand -base64 32
ENCRYPTION_KEY=

# Origens permitidas para CORS (lista separada por vírgula). Inclua o domínio do front.
CORS_ORIGINS=http://localhost:5173

# URL pública do front (links em e-mails de convite). Opcional — usa a primeira origem de CORS_ORIGINS.
FRONTEND_URL=http://localhost:5173

# SMTP (Nodemailer) — envio de convites de organização. Se SMTP_HOST estiver vazio, convites são criados sem e-mail.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Workflows <no-reply@example.com>"

# AI providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

NODE_ENV=development
PORT=3000
# trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/workflows

# Redis (BullMQ)
REDIS_URL=redis://127.0.0.1:6379

# Better Auth — gere um segredo: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Criptografia de secrets em repouso — 32 bytes base64. Gere: openssl rand -base64 32
ENCRYPTION_KEY=

# Origens permitidas para CORS + trustedOrigins do Better Auth.
# Lista separada por vírgula. Inclua o domínio do front.
CORS_ORIGINS=http://localhost:5173

# URL pública do front (links em e-mails de convite). Opcional — usa a primeira origem de CORS_ORIGINS.
FRONTEND_URL=http://localhost:5173

# SMTP (Nodemailer) — envio de convites de organização. Se SMTP_HOST estiver vazio, convites são criados sem e-mail.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Workflows <no-reply@example.com>"

# AI providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
